        "open_web_browser",
        "navigate",
        "go_back",
        "go_forward",
        "search",
        "click_at",
        "hover_at",
        "drag_and_drop",
        "type_text_at",
        "key_combination",
        "scroll_document",
        "scroll_at",
        "wait_5_seconds",
        "done",
        "error"
      ],
      "limitations": [
        "Action vocabulary is fixed by the model's CU tool — cannot add custom actions",
        "Gemini uses normalized 0-999 coordinates; Claude uses real pixels",
        "No DOM/selector-level interaction (pixel-based only)",
        "Safety confirmations require callback handling"
      ],
      "environment_requirements": [
        "Playwright Chromium (browser mode)",
        "Xvfb + xdotool + scrot (desktop mode)",
        "DISPLAY=:99 set for desktop mode"
      ]
    }
