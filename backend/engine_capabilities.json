    "computer_use": {
      "display_name": "Computer Use (Native CU Protocol) ★ Recommended",
      "description": "Unified engine using Gemini 3 Flash and Claude 4.6 Sonnet native Computer Use tool protocols. Structured function_call / tool_use instead of text-parsed JSON. Supports browser (Playwright) and desktop (xdotool+scrot) backends. This is the recommended engine for new tasks.",
      "fallback_priority": 6,
      "recommended": true,
      "categories": {
        "navigation": [
          "open_web_browser",
          "navigate",
          "go_back",
          "go_forward",
          "search"
