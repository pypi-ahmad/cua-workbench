# CUA environment variables
# Copy this to .env and fill in values

# API Keys — set these to avoid entering keys in the UI every time.
# The backend resolves keys in priority order: UI input > .env file > system env var.
# GOOGLE_API_KEY=your-google-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Model override
# GEMINI_MODEL=gemini-3-flash-preview

# Docker
CONTAINER_NAME=cua-environment
SCREEN_WIDTH=1440
SCREEN_HEIGHT=900
# VNC_PASSWORD=             # Set a VNC password for the container (empty = no password)

# Agent service (Playwright inside container)
AGENT_SERVICE_HOST=127.0.0.1
AGENT_SERVICE_PORT=9222

# Playwright MCP service (runs inside container, exposed on port 8931)
# IMPORTANT: Use 'localhost' (not '127.0.0.1') — Playwright MCP's
# allowed-host check rejects Host headers with raw IP addresses.
PLAYWRIGHT_MCP_HOST=localhost
PLAYWRIGHT_MCP_PORT=8931
PLAYWRIGHT_MCP_PATH=/mcp
PLAYWRIGHT_MCP_AUTOSTART=0
PLAYWRIGHT_MCP_COMMAND=npx
PLAYWRIGHT_MCP_ARGS=-y @playwright/mcp@0.0.70

# Agent mode: "browser" (Playwright) or "desktop" (xdotool)
AGENT_MODE=browser

# Agent
MAX_STEPS=50
STEP_TIMEOUT=30.0
GEMINI_RETRY_ATTEMPTS=3

# Debug mode (set to 1 to enable verbose logging)
DEBUG=0
